# Asana Configuration
# Get your token from: https://app.asana.com/0/developer-console
ASANA_TOKEN=your_asana_personal_access_token

# Asana Project ID (where tasks will be created)
# Find this in your Asana project URL: https://app.asana.com/0/<PROJECT_ID>/list
ASANA_PROJECT_ID=1201234567890123

# Asana Workspace ID (optional - if not using project)
# Find this in your Asana workspace URL
ASANA_WORKSPACE_ID=1201234567890123
